<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<VBox spacing="20.0" prefWidth="450.0" style="-fx-padding: 25; -fx-font-family: 'Times New Roman';"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.shoe_store.controller.OrderFormController">

    <Label fx:id="formTitle" text="Управление заказом" style="-fx-font-size: 18; -fx-font-weight: bold;" />

    <GridPane hgap="10" vgap="15">
        <Label text="Артикул заказа:" GridPane.rowIndex="0" />
        <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Статус:" GridPane.rowIndex="1" />
        <ComboBox fx:id="statusBox" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" />

        <Label text="Пункт выдачи:" GridPane.rowIndex="2" />
        <ComboBox fx:id="addressBox" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity" />

        <Label text="Дата заказа:" GridPane.rowIndex="3" />
        <DatePicker fx:id="orderDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Дата выдачи:" GridPane.rowIndex="4" />
        <DatePicker fx:id="pickupDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Отмена" onAction="#handleBack" prefWidth="100" />
        <Button text="Сохранить" onAction="#handleSave" prefWidth="120"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>
</VBox>