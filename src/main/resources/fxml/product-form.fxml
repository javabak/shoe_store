<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.shoe_store.controller.ProductFormController"
      prefWidth="600.0" style="-fx-padding: 20;">

    <Label text="Редактирование / Добавление товара">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Separator />

    <HBox spacing="20.0">
        <VBox spacing="10.0" alignment="TOP_CENTER">
            <Label text="Фото товара" />
            <StackPane style="-fx-border-color: #cccccc; -fx-border-width: 1;">
                <ImageView fx:id="imageView" fitHeight="200.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" />
            </StackPane>
            <Button text="Загрузить фото" onAction="#handleUploadImage" maxWidth="Infinity"/>
            <Label text="Лимит: 300x200 пикселей" style="-fx-font-size: 10; -fx-text-fill: gray;" />
        </VBox>

        <GridPane hgap="10.0" vgap="10.0" HBox.hgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints minWidth="100.0" prefWidth="120.0"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="ID товара:" GridPane.rowIndex="0"/>
            <TextField fx:id="idField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Наименование:" GridPane.rowIndex="1"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Категория:" GridPane.rowIndex="2"/>
            <ComboBox fx:id="categoryBox" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>

            <Label text="Производитель:" GridPane.rowIndex="3"/>
            <ComboBox fx:id="manufacturerBox" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity"/>

            <Label text="Поставщик:" GridPane.rowIndex="4"/>
            <TextField fx:id="supplierField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Ед. измерения:" GridPane.rowIndex="5"/>
            <TextField fx:id="unitField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        </GridPane>
    </HBox>

    <VBox spacing="10.0">
        <Label text="Описание товара:" />
        <TextArea fx:id="descriptionField" prefHeight="80.0" wrapText="true" />

        <HBox spacing="15.0">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Цена (₽):" />
                <TextField fx:id="priceField" promptText="0.00" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Скидка (%):" />
                <TextField fx:id="discountField" promptText="0" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS">
                <Label text="На складе:" />
                <TextField fx:id="quantityField" promptText="0" />
            </VBox>
        </HBox>
    </VBox>

    <Separator />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button text="Назад" onAction="#handleBack" prefWidth="100.0"
                style="-fx-background-color: #f0f0f0; -fx-border-color: #cccccc;" />
        <Button text="Сохранить" onAction="#handleSave" prefWidth="120.0"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>

</VBox>